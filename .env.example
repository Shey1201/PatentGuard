# PatentGuard 环境配置模板

# =====================================================
# Supabase 配置
# 从 Supabase Dashboard -> Project Settings -> API 获取
# =====================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# =====================================================
# 数据库配置
# 推荐使用 Supabase PostgreSQL，也可以使用本地 PostgreSQL + pgvector
# 格式: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# =====================================================
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# =====================================================
# 文件存储
# 默认使用 Supabase Storage
# =====================================================
USE_SUPABASE_STORAGE=true
STORAGE_BUCKET=documents
UPLOAD_DIR=./uploads

# =====================================================
# MinIO 配置
# 仅在不使用 Supabase Storage 时需要
# =====================================================
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET_NAME=patentguard
# MINIO_SECURE=false

# =====================================================
# Redis 配置
# 当前项目可使用本地 Redis，也可替换为云服务
# =====================================================
REDIS_URL=redis://localhost:6379/0

# =====================================================
# JWT 配置
# 生产环境必须替换 SECRET_KEY
# =====================================================
SECRET_KEY=patentguard-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =====================================================
# 演示数据
# 本地演示可设为 true；生产环境建议设为 false
# =====================================================
ENABLE_DEMO_MODE=false
VITE_ENABLE_DEMO_MODE=false

# =====================================================
# LLM 默认配置
# 用户也可以在系统界面配置自己的模型参数。
# 当前后端按 Chat Completions 兼容格式调用：
# POST {LLM_BASE_URL}/chat/completions
# 因此这里不限制具体厂商，只需填写兼容接口地址、模型名和 API Key。
# =====================================================
LLM_PROVIDER=custom
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://your-llm-endpoint.example/v1
LLM_MODEL=your-chat-model

# =====================================================
# Embedding 配置
# =====================================================
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=https://your-embedding-endpoint.example/v1

# =====================================================
# 文档分块配置
# =====================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# =====================================================
# 检索配置
# =====================================================
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.5

# =====================================================
# CORS 配置
# =====================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =====================================================
# 日志配置
# =====================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
